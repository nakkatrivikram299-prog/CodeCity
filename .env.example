# ──────────────────────────────────────────────────
# CodeCity — Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# GitHub Personal Access Token (OPTIONAL)
# Without this, you get 60 API requests/hour (public API).
# With a token, you get 5,000 requests/hour.
#
# How to get a token:
#   1. Go to: https://github.com/settings/tokens
#   2. Click "Generate new token (classic)"
#   3. Select scopes: public_repo (for public repos)
#   4. Copy the token below
# ──────────────────────────────────────────────────

VITE_GITHUB_TOKEN=
